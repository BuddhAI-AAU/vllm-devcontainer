from fastapi import APIRouter, Request
from fastapi.responses import StreamingResponse
import httpx
import json

from services.conversation_store import JsonConversationSore

router = APIRouter()

VLLM_URL = "http://localhost:8000/v1/completions"
MODEL = "nvidia/Qwen3-Next-80B-A3B-Thinking-NVFP4"

store = JsonConversationSore()


# ------------------------------------------------------------
#  Helper: Extract user text from OpenResponses format
# ------------------------------------------------------------
def extract_user_text(openresponses_body: dict) -> str:
    """
    Extracts all user text from an OpenResponses request body.
    Returns a single concatenated string.
    """
    user_text_parts = []

    for item in openresponses_body.get("input", []):
        if item.get("role") != "user":
            continue

        for content in item.get("content", []):
            if content.get("type") == "input_text":
                text = content.get("text", "")
                if text:
                    user_text_parts.append(text)

    return "\n".join(user_text_parts)


# ------------------------------------------------------------
#  Main endpoint: /responses
# ------------------------------------------------------------
@router.post("/responses", response_class=StreamingResponse)
async def get_open_responses(request: Request):

    # Parse incoming JSON
    body = await request.json()

    # Load or create conversation
    conversation_id = store.check_conv(body.get("conversation_id"))

    # Extract user text from OpenResponses
    user_input = extract_user_text(body)

    # Save user message
    store.add_message(conversation_id, "user", user_input)

    # Prepare vLLM payload
    vllm_payload = {
        "model": MODEL,
        "prompt": user_input,
        "max_tokens": 500,
        "temperature": 0.7,
        "stream": True
    }

    # Send request to vLLM
    async with httpx.AsyncClient() as client:
        vllm_response = await client.post(VLLM_URL, json=vllm_payload, timeout=None)

    assistant_buffer = ""

    # ------------------------------------------------------------
    #  Streaming generator for SSE output
    # ------------------------------------------------------------
    async def event_generator():
        nonlocal assistant_buffer

        # Send conversation_id first
        yield f"event: conversation_id\ndata: {conversation_id}\n\n"

        async for line in vllm_response.aiter_lines():
            if not line.startswith("data: "):
                continue

            data = line[len("data: "):]

            if data == "[DONE]":
                # Save assistant message
                store.add_message(conversation_id, "assistant", assistant_buffer)

                yield "event: response.completed\ndata: {}\n\n"
                break

            # Parse streamed chunk
            chunk = json.loads(data)
            delta_text = chunk["choices"][0]["text"]

            # Accumulate assistant text
            assistant_buffer += delta_text

            # Send delta event
            event_data = json.dumps({"delta": delta_text})
            yield f"event: response.output_text.delta\ndata: {event_data}\n\n"

    return StreamingResponse(event_generator(), media_type="text/event-stream")
